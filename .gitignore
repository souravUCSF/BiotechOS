.DS_Store

# Raw data exports — large, regenerable; never commit
data/raw/
*.csv.gz

# Processed/curated demo tables are committed from data/curated/ (keep those small)

# Local state + compute cache
data/biotechos.db
data/cache/

# Eval run artifacts (timestamped); baseline.json + *.jsonl cases ARE committed.
data/evals/results/

# Anonymization maps — SECRET.
data/corpus_maps/
# Corpus: only target/structure anonymized; vendor names, employee emails, phones,
# and codes are REAL third-party PII → keep local, never commit. Regenerate via
# ingest.anonymize.build_corpus from the raw archive (~/DataStore).
data/corpus/

# Python
backend/.venv/
__pycache__/
*.pyc

# Node
frontend/node_modules/
frontend/.next/
.claude/settings.local.json

# Local secrets — never commit
backend/secrets.env
.env
